# ============================================================
# Docker Compose Environment Template — xsjprd55
# Copy to .env before running: docker compose up -d
# ============================================================

# Core runtime
NODE_ENV=production
DEPLOYMENT_TARGET=vps
PORT=3000
APP_URL=https://bot.abcx124.xyz
TRADING_MODE=paper

# Supabase (Required)
SUPABASE_URL=your-project-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Telegram (Required for signal notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_GROUP_CHAT_ID=your-telegram-chat-id
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id
CRON_SECRET=your-cron-secret

# Telegram rate limiting (optional)
TELEGRAM_RATE_LIMIT_TOKENS=25
TELEGRAM_RATE_LIMIT_WINDOW_MS=60000
TELEGRAM_ADMIN_ALERT_TOKENS=10
TELEGRAM_ADMIN_ALERT_WINDOW_MS=60000

# Supabase connection pooling (optional)
SUPABASE_TIMEOUT_MS=15000
SUPABASE_MAX_RETRIES=3

# Request timeout (optional)
REQUEST_TIMEOUT_MS=30000

# ML Service (Docker internal network)
ML_SERVICE_URL=http://ml-service:8010
ENABLE_ML_SIGNALS=true

# Mock Trading
MOCK_STARTING_BALANCE=1000000
MOCK_MAX_LEVERAGE=20
MOCK_RISK_PER_TRADE_PCT=2
MOCK_ABSOLUTE_MAX_LEVERAGE=20
MOCK_DAILY_LOSS_CUTOFF_PCT=5
MOCK_MAX_OPEN_TRADES=50
MOCK_MIN_RR_RATIO=1.0
ENABLE_MOCK_TRADING_WORKER=true
ENABLE_AGGRESSIVE_MOCK_WORKER=true
ENABLE_TV_TA_SCAN=true

# Execution Worker
EXECUTION_POLL_INTERVAL_MS=30000

# Exchange API Keys (Read-only for signal generation)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# AI Provider Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# External API Keys
COINGECKO_API_KEY=
LUNARCRUSH_API_KEY=
CRYPTOPANIC_API_KEY=

# Brain Configuration
BRAIN_SCAN_INTERVAL_MS=300000
BRAIN_LEARNING_INTERVAL_MS=86400000
BRAIN_SYMBOLS=BTCUSDT,ETHUSDT
BRAIN_TIMEFRAMES=15m,1h,4h
BRAIN_AI_PROVIDER=local
BRAIN_LIVE_MODE=false

# Research Agent
ENABLE_RESEARCH_AGENT=true

# PM2 Log Rotation (Docker)
PM2_LOG_ROTATE_MAX_SIZE=10M
PM2_LOG_ROTATE_RETAIN=5
