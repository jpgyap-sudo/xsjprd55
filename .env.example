# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_ADMIN_USER_ID=your-admin-telegram-user-id
TELEGRAM_GROUP_CHAT_ID=your-group-chat-id

# Exchange APIs (read-only recommended)
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BYBIT_API_KEY=your-bybit-api-key
BYBIT_API_SECRET=your-bybit-api-secret
OKX_API_KEY=your-okx-api-key
OKX_API_SECRET=your-okx-api-secret
OKX_API_PASSPHRASE=your-okx-passphrase

# Trading Config
TRADING_MODE=paper
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=15m
MAX_POSITION_SIZE_USD=100
DAILY_LOSS_LIMIT_USD=50
SIGNAL_COOLDOWN_MINUTES=30

# Signal Engine
SIGNAL_CONFIDENCE_THRESHOLD=0.70
EMA_SHORT_PERIOD=9
EMA_LONG_PERIOD=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# Cron & Monitoring
MARKET_SCAN_INTERVAL_MINUTES=5
HEALTH_CHECK_INTERVAL_MINUTES=30
LOG_LEVEL=info

# Cron Secret (protects cron-triggered endpoints from unauthorized access)
# Set this and add x-cron-secret header when calling from external cron services
CRON_SECRET=your-cron-secret-key

# News Signal Settings
NEWS_SIGNAL_COOLDOWN_MINUTES=15
NEWS_MIN_CONFIDENCE=0.60
NEWS_SCAN_MAX_AGE_MINUTES=60

# Deployment & Optional AI
VERCEL_PRODUCTION_URL=https://your-app.vercel.app
ANTHROPIC_API_KEY=your-anthropic-api-key
