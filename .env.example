# ============================================================
# xsjprd55 Trading Signal Bot — Environment Configuration
# Copy this file to .env and fill in your actual values
# ============================================================

# Core runtime
NODE_ENV=production
DEPLOYMENT_TARGET=vps
PORT=3000
APP_URL=https://bot.abcx124.xyz
TRADING_MODE=paper

# Supabase (Required for all database operations)
SUPABASE_URL=your-project-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Telegram (Required for signal notifications)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_GROUP_CHAT_ID=your-telegram-chat-id
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id
CRON_SECRET=your-cron-secret
NEWS_INGEST_MAX_AGE_MINUTES=720
NEWS_INGEST_INTERVAL_SECONDS=180

# ============================================================
# MOCK TRADING CONFIGURATION
# ============================================================

# Mock Trading Execution Optimizer v3
# ML Service
ML_SERVICE_URL=http://localhost:5000
ENABLE_ML_SIGNALS=true

# Mock Trading
MOCK_STARTING_BALANCE=1000000
MOCK_MAX_LEVERAGE=20
MOCK_RISK_PER_TRADE_PCT=2
MOCK_ABSOLUTE_MAX_LEVERAGE=20
MOCK_DAILY_LOSS_CUTOFF_PCT=5
MOCK_MAX_OPEN_TRADES=50
MOCK_MIN_RR_RATIO=1.0
ENABLE_MOCK_TRADING_WORKER=true

# Aggressive Mock Trading
ENABLE_AGGRESSIVE_MOCK_WORKER=true
ENABLE_TV_TA_SCAN=true

# Execution Worker
EXECUTION_POLL_INTERVAL_MS=30000
MAX_SIGNAL_AGE_MINUTES=720

# Public price feeds for paper/mock monitoring. No API keys required.
# Hyperliquid is tried first; Binance/Bybit/OKX remain fallbacks for symbols HL does not list.
PRICE_SOURCE_ORDER=hyperliquid,binance,bybit,okx

# Perpetual Signal Trader
# Paper-only signal-driven perpetual simulator. Requires Supabase perpetual schema.
PERPETUAL_TRADER_INTERVAL_SECONDS=60
PERPETUAL_MAX_OPEN_TRADES=5
PERPETUAL_MIN_CONFIDENCE=0.55
PERPETUAL_MAX_LEVERAGE=10
PERPETUAL_MAX_RISK_PER_TRADE=0.01
PERPETUAL_DAILY_MAX_LOSS_PCT=0.05

# ============================================================
# VPS DEPLOYMENT CONFIGURATION
# ============================================================

# VPS Connection (Required for deploy-checker and auto-deployment)
VPS_IP=165.22.110.111
VPS_USER=root
VPS_SSH_KEY=/root/.ssh/id_ed25519_roo
GITHUB_REPO=jpgyap-sudo/xsjprd55
GITHUB_BRANCH=main

# Deploy Checker Timeouts
DEPLOY_CHECK_SSH_TIMEOUT_MS=15000
DEPLOY_CHECK_HTTP_TIMEOUT_MS=10000

# Auto-Deploy Settings
ENABLE_AUTO_DEPLOY=true
AUTO_DEPLOY_INTERVAL_MINUTES=2
DEPLOY_MAINTENANCE_START_HOUR=23
DEPLOY_MAINTENANCE_END_HOUR=6
TELEGRAM_DEPLOY_NOTIFICATIONS=true

# ============================================================
# EXTERNAL API KEYS (Optional but recommended)
# ============================================================

# Exchange API Keys (Read-only recommended)
BINANCE_API_KEY=optional
BINANCE_API_SECRET=optional
BYBIT_API_KEY=optional
BYBIT_API_SECRET=optional

# News & Social APIs
CRYPTOPANIC_API_KEY=optional
LUNARCRUSH_API_KEY=optional

# AI/ML APIs
OPENAI_API_KEY=optional
ANTHROPIC_API_KEY=optional

# ============================================================
# FEATURE FLAGS
# ============================================================

# TradingView Webhook
TRADINGVIEW_WEBHOOK_SECRET=your-tradingview-webhook-secret

# Bug Hunter Agent
BUG_HUNTER_ENABLED=true
BUG_HUNTER_BASE_URL=https://bot.abcx124.xyz
BUG_HUNTER_INTERVAL_SECONDS=900
BUG_HUNTER_TIMEOUT_MS=15000
BUG_HUNTER_NOTIFY_TELEGRAM=true
BUG_HUNTER_ASSIGN_CRITICAL=true

# Research Agent
ENABLE_RESEARCH_AGENT=true
RESEARCH_AGENT_INTERVAL_MS=600000

# Learning Loop
ENABLE_LEARNING_LOOP=true
LEARNING_LOOP_INTERVAL_MS=3600000

# Signal Generator
SIGNAL_GENERATOR_INTERVAL_MS=900000

# ============================================================
# SAFETY GATES (DO NOT DISABLE UNLESS YOU KNOW WHAT YOU'RE DOING)
# ============================================================

# NEVER enable live trading without proper risk management
ENABLE_LIVE_TRADING=false
MAX_POSITION_SIZE_USD=100000
MAX_DAILY_LOSS_USD=5000
