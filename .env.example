# ============================================================
# Trading Signal Bot — Environment Variables
# Copy this to .env and fill in your secrets.
# NEVER commit .env to git.
# ============================================================

# ── Deployment Target ───────────────────────────────────────
# vercel | vps
DEPLOYMENT_TARGET=vps

# ── Server (VPS only) ───────────────────────────────────────
PORT=3000
HOST=0.0.0.0
APP_URL=https://your-vps-ip-or-domain.com

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Telegram Bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_ADMIN_USER_ID=your-admin-telegram-user-id
TELEGRAM_GROUP_CHAT_ID=your-group-chat-id
TELEGRAM_ADMIN_CHAT_ID=

# ── Exchange API (READ-ONLY recommended for signals) ────────
# Get from Binance → API Management → Create API Key
# Restrict to "Enable Reading" only for signal generation.
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# Optional: Bybit read-only keys
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Optional: OKX keys
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# ── Trading Configuration ───────────────────────────────────
TRADING_MODE=paper
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=15m

# Default pairs and timeframes (comma-separated)
DEFAULT_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT
TIMEFRAMES=15m,1h,4h

# Risk limits
MAX_POSITION_SIZE_USD=100
DAILY_LOSS_LIMIT_USD=50
SIGNAL_COOLDOWN_MINUTES=15

# ── Signal Engine ───────────────────────────────────────────
SIGNAL_CONFIDENCE_THRESHOLD=0.70
EMA_SHORT_PERIOD=9
EMA_LONG_PERIOD=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# ── LunarCrush ──────────────────────────────────────────────
# Get from https://lunarcrush.com/developers (free tier available)
LUNARCRUSH_API_KEY=your-lunarcrush-api-key

# ── AI / Claude ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Cron Schedules (VPS only; Vercel uses vercel.json) ─────
# Set to "false" to disable a cron job
CRON_SIGNALS=*/15 * * * *
CRON_MARKET=0 * * * *
CRON_WEEKLY=0 4 * * 0
CRON_SECRET=your-cron-secret-here

# ── Cron & Monitoring ───────────────────────────────────────
MARKET_SCAN_INTERVAL_MINUTES=5
HEALTH_CHECK_INTERVAL_MINUTES=30

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIR=./logs

# ── Feature Flags ───────────────────────────────────────────
ENABLE_NEWS=true
ENABLE_SOCIAL=true
ENABLE_WEBSOCKET=false
ENABLE_OI_WORKER=true
ENABLE_LIQUIDATION_WORKER=true
ENABLE_HEALTH_WORKER=true
ENABLE_NOTIFICATION_WORKER=true
ENABLE_FALLBACK_CRAWLER=true
ENABLE_CONTINUOUS_BACKTESTER=true
ENABLE_MOCK_TRADING_WORKER=true
ENABLE_APP_IMPROVEMENT_WORKER=true
ENABLE_LEARNING_WORKER=true
ENABLE_WALLET_TRACKER_WORKER=true
ENABLE_DIAGNOSTIC_WORKER=true
ENABLE_SOCIAL_CRAWLER_WORKER=true
WALLET_TRACKER_INTERVAL_MS=300000

# ── Wallet Tracker ──────────────────────────────────────────
# Add wallet addresses to track (up to 20)
# Format: WALLET_N=address,label
WALLET_1=0x1234abcd,Whale1
WALLET_2=
WALLET_3=

# ── Learning Loop ───────────────────────────────────────────
CRON_LEARNING=0 */6 * * *
LEARNING_LOOP_ENABLED=true
SUGGESTION_AI_ENABLED=true
SUGGESTION_MIN_PATTERNS=20

# ── Backtesting / Mock Trading ──────────────────────────────
MOCK_STARTING_BALANCE=1000
MOCK_MAX_LEVERAGE=3
MOCK_RISK_PER_TRADE_PCT=1

# ── WebSocket (VPS only, optional) ──────────────────────────
WS_PORT=8080

# ── Vercel Legacy (only if dual-deploying) ──────────────────
VERCEL_PRODUCTION_URL=
