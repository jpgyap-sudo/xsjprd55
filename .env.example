# Core runtime
NODE_ENV=production
DEPLOYMENT_TARGET=vps
PORT=3000
APP_URL=https://bot.abcx124.xyz
TRADING_MODE=paper

# Supabase
SUPABASE_URL=your-project-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_GROUP_CHAT_ID=your-telegram-chat-id
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id
CRON_SECRET=your-cron-secret

# Mock Trading Execution Optimizer v3
MOCK_STARTING_BALANCE=1000000
MOCK_MAX_LEVERAGE=20
MOCK_RISK_PER_TRADE_PCT=2
MOCK_ABSOLUTE_MAX_LEVERAGE=20
MOCK_DAILY_LOSS_CUTOFF_PCT=5
ENABLE_MOCK_TRADING_WORKER=true

# Public price feeds for paper/mock monitoring. No API keys required.
# Hyperliquid is tried first; Binance/Bybit/OKX remain fallbacks for symbols HL does not list.
PRICE_SOURCE_ORDER=hyperliquid,binance,bybit,okx

# Execution worker poll interval (ms)
EXECUTION_POLL_INTERVAL_MS=30000

# TradingView Webhook
TRADINGVIEW_WEBHOOK_SECRET=your-tradingview-webhook-secret

# Bug Hunter Agent
BUG_HUNTER_ENABLED=true
BUG_HUNTER_BASE_URL=https://bot.abcx124.xyz
BUG_HUNTER_INTERVAL_SECONDS=900
BUG_HUNTER_TIMEOUT_MS=15000
BUG_HUNTER_NOTIFY_TELEGRAM=true
BUG_HUNTER_ASSIGN_CRITICAL=true
