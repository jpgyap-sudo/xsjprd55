# ============================================================
# Production Environment — bot.abcx124.xyz (VPS)
# Copy this to .env on your server and fill in real values.
# NEVER commit .env with real secrets.
# ============================================================

# --- Core App ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
DEPLOYMENT_TARGET=vps
APP_URL=https://bot.abcx124.xyz

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=generate-a-32-char-secret
TELEGRAM_ADMIN_USER_ID=your-telegram-user-id
TELEGRAM_GROUP_CHAT_ID=your-group-chat-id
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# --- Exchange APIs (read-only keys recommended) ---
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-secret
BYBIT_API_KEY=your-bybit-api-key
BYBIT_API_SECRET=your-bybit-secret
OKX_API_KEY=your-okx-api-key
OKX_API_SECRET=your-okx-secret
OKX_PASSPHRASE=your-okx-passphrase

# --- AI Provider (Kimi = primary, Anthropic = fallback) ---
AI_PROVIDER=kimi
KIMI_API_KEY=sk-your-kimi-key-here
KIMI_MODEL=kimi-k2-6
KIMI_BASE_URL=https://api.moonshot.cn/v1
ANTHROPIC_API_KEY=your-claude-api-key

# --- Signal Settings ---
TRADING_MODE=paper
DEFAULT_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT
TIMEFRAMES=15m,1h,4h
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=15m
SIGNAL_CONFIDENCE_THRESHOLD=0.65
SIGNAL_COOLDOWN_MINUTES=30
MAX_POSITION_SIZE_USD=500
DAILY_LOSS_LIMIT_USD=200

# --- Risk / Mock Trading ---
MOCK_STARTING_BALANCE=10000
MOCK_MAX_LEVERAGE=3
MOCK_RISK_PER_TRADE_PCT=1

# --- Data Feeds ---
LUNARCRUSH_API_KEY=your-lunarcrush-api-key

# --- Cron / Security ---
CRON_SECRET=generate-a-32-char-secret
CRON_SIGNALS=*/15 * * * *
CRON_MARKET=0 * * * *
CRON_WEEKLY=0 4 * * 0
CRON_LEARNING=0 */6 * * *

# --- Logging ---
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_DIR=./logs

# --- Feature Flags (all enabled by default) ---
ENABLE_NEWS=true
ENABLE_SOCIAL=true
ENABLE_WEBSOCKET=false
ENABLE_OI_WORKER=true
ENABLE_LIQUIDATION_WORKER=true
ENABLE_HEALTH_WORKER=true
ENABLE_NOTIFICATION_WORKER=true
ENABLE_FALLBACK_CRAWLER=true
ENABLE_CONTINUOUS_BACKTESTER=true
ENABLE_MOCK_TRADING_WORKER=true
ENABLE_APP_IMPROVEMENT_WORKER=true
ENABLE_LEARNING_WORKER=true
ENABLE_DIAGNOSTIC_WORKER=true
ENABLE_SOCIAL_CRAWLER_WORKER=true
ENABLE_WALLET_TRACKER_WORKER=true
WALLET_TRACKER_INTERVAL_MS=300000

# --- WebSocket (optional, VPS only) ---
WS_PORT=8080
