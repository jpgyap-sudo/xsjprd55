# ============================================================
# Production Environment — bot.abcx124.xyz (VPS)
# Copy this to .env on your server and fill in real values.
# NEVER commit .env with real secrets.
# ============================================================

# --- Core App ---
NODE_ENV=production
PORT=3000
DEPLOYMENT_TARGET=vps

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=generate-a-32-char-secret
TELEGRAM_ADMIN_USER_ID=your-telegram-user-id
TELEGRAM_GROUP_CHAT_ID=your-group-chat-id

# --- Exchange APIs (read-only keys recommended) ---
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-secret
BYBIT_API_KEY=your-bybit-api-key
BYBIT_API_SECRET=your-bybit-secret
OKX_API_KEY=your-okx-api-key
OKX_API_SECRET=your-okx-secret
OKX_PASSPHRASE=your-okx-passphrase

# --- Signal Settings ---
TRADING_MODE=paper
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=15m
SIGNAL_CONFIDENCE_THRESHOLD=0.65
SIGNAL_COOLDOWN_MINUTES=30
MAX_POSITION_SIZE_USD=500
DAILY_LOSS_LIMIT_USD=200

# --- Logging ---
LOG_LEVEL=info

# --- Cron / Security ---
CRON_SECRET=generate-a-32-char-secret

# --- Optional: AI ---
# AI_PROVIDER=kimi   # or 'anthropic' for Claude only
KIMI_API_KEY=your-kimi-api-key-from-moonshot
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.cn/v1
ANTHROPIC_API_KEY=your-claude-api-key
